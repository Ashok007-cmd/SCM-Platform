# =============================================================
# SCM Platform — Environment Variables Example
# Copy this file to .env and populate with real values.
# NEVER commit .env to version control.
# =============================================================

# ─── AWS ──────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_iam_access_key
AWS_SECRET_ACCESS_KEY=your_iam_secret_key
AWS_REGION=us-east-1

# ─── Container Registry ───────────────────────────────────────
DOCKERHUB_USERNAME=your_dockerhub_username
DOCKERHUB_TOKEN=your_dockerhub_pat

# ─── Database ─────────────────────────────────────────────────
DB_POSTGRES_PASSWORD=change_me_strong_password
DB_MONGO_PASSWORD=change_me_strong_password

# ─── Kafka / Confluent Cloud ──────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:29092
KAFKA_API_KEY=your_confluent_api_key
KAFKA_API_SECRET=your_confluent_api_secret

# ─── Spring Boot Backend ──────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=scm_platform
DB_USERNAME=scm_user
DB_PASSWORD=change_me_strong_password
REDIS_HOST=localhost
REDIS_PORT=6379
# JWT_SECRET: REQUIRED in production. Must be base64-encodable string, min 32 chars.
# Generate with: openssl rand -base64 48
JWT_SECRET=replace_with_base64_encoded_secret_min_32_chars
JWT_EXPIRATION_MS=86400000
JWT_ISSUER=scm-platform
# ALLOWED_ORIGINS: comma-separated list of allowed frontend origins (no wildcards)
ALLOWED_ORIGINS=https://your-production-domain.com
# SMOKE_TEST_BASE_URL: base URL used by Newman smoke tests in CD pipeline
SMOKE_TEST_BASE_URL=https://your-production-domain.com

# ─── Monitoring ───────────────────────────────────────────────
DATADOG_API_KEY=your_datadog_api_key
DATADOG_APP_KEY=your_datadog_app_key
DD_ENV=development
DD_SERVICE=scm-backend
DD_VERSION=1.0.0

# ─── Frontend ─────────────────────────────────────────────────
VITE_API_BASE_URL=/api/v1

# ─── Terraform State Backend ──────────────────────────────────
TF_STATE_BUCKET=scm-platform-terraform-state
TF_STATE_LOCK_TABLE=scm-platform-terraform-locks
